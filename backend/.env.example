# Copy to .env and adjust. Never commit real secrets.
ENVIRONMENT=development
DATABASE_URL=sqlite:///./aurora.db
# For PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://aurora:aurora@localhost:5432/aurora
SECRET_KEY=generate-a-long-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:3000"]
DEFAULT_TAX_RATE=0.10
FIRST_ADMIN_EMAIL=admin@aurora.dev
FIRST_ADMIN_PASSWORD=admin12345
